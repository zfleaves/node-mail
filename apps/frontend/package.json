{
  "name": "@node-mail/frontend",
  "version": "1.0.0",
  "description": "电商管理后台前端 - 基于 Vue3 和 TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.2.0",
    "element-plus": "^2.9.1",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "@node-mail/utils": "workspace:*",
    "@node-mail/constants": "workspace:*",
    "@node-mail/components": "workspace:*",
    "@node-mail/layouts": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0",
    "eslint": "^9.18.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/eslint-config-prettier": "^10.1.0",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "sass": "^1.83.4",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0",
    "npm": ">=10.8.1"
  }
}
